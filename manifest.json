{
  "manifest_version": 3,
  "name": "DLsite Score",
  "version": "1.9.1",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://www.dlsite.com/*",
    "https://raw.githubusercontent.com/tehuyoryu-cpu/siteruns23432/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.dlsite.com/*"
      ],
      "js": [
        "tag_dict.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
