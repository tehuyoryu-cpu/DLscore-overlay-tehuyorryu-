{
  "manifest_version": 3,
  "name": "DLsite Score",
  "version": "1.8",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://www.dlsite.com/*",
    "https://dldshare.net/*",
    "https://raw.githubusercontent.com/tehuyoryu-cpu/siteruns23432/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dlsite.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
